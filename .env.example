# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库
DATABASE_URL=sqlite:///db.sqlite3

# Redis
REDIS_URL=redis://localhost:6379/5
REDIS_HOST=localhost
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://localhost:6379/5
CELERY_RESULT_BACKEND=redis://localhost:6379/5

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Page Agent / OpenCode
AGENT_SERVER_BASE_URL=http://127.0.0.1:9002
AGENT_SERVER_USERNAME=opencode
AGENT_SERVER_PASSWORD=
MCP_ACCESS_TOKEN=
AGENT_MODEL_PROVIDER_ID=opencode
AGENT_MODEL_ID=big-pickle
AGENT_MODEL_VARIANT=
AGENT_REMOTE_AGENT_NAME=build
AGENT_SHOW_FREE_MODELS=false

# 大模型配置（可选，不配置则使用Mock模式）
# LLM配置
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL_NAME=
# 示例：DeepSeek
# LLM_API_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-你的密钥
# LLM_MODEL_NAME=deepseek-chat
# 示例：通义千问
# LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-你的密钥
# LLM_MODEL_NAME=qwen-plus
# 示例：智谱GLM
# LLM_API_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_API_KEY=你的密钥
# LLM_MODEL_NAME=glm-4

# 文生图配置（可选）
TEXT2IMAGE_API_URL=
TEXT2IMAGE_API_KEY=
TEXT2IMAGE_MODEL_NAME=

# 图生视频配置（可选）
IMAGE2VIDEO_API_URL=
IMAGE2VIDEO_API_KEY=
IMAGE2VIDEO_MODEL_NAME=
